  "description": "Moon-aware agentic dev loop for TypeScript monorepos — scopes work to affected projects via `moon query`, implements TDD-first, verifies via affected :typecheck/:lint/:test before handoff. Cross-runtime (Claude Code + Codex).",
  "version": "1.0.0",
  "author": {
    "name": "g-bastianelli"
  },
  "repository": "https://github.com/g-bastianelli/nuthouse",
  "homepage": "https://github.com/g-bastianelli/nuthouse",
  "skills": "./skills/",
  "agents": [
    "./agents/affected-scout.md",
    "./agents/verify-runner.md",
    "./agents/change-auditor.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claudecode/hooks/session-start.mjs\""
          }
        ]
      }
    ]
  }
